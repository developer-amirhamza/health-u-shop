generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(dbgenerated("gen_random_uuid()"))
  firstName              String?
  lastName               String?
  email                  String    @unique
  password               String
  verify_email           Boolean?  @default(false)
  status                 String?   @default("ACTIVE")
  avatar                 String?
  mobile                 String?
  last_login_date        DateTime? @db.Timestamp(6)
  refresh_token          String?
  forgot_password_otp    String?
  forgot_password_expire DateTime? @db.Timestamp(6)
  createdAt              DateTime? @default(now()) @db.Timestamp(6)
  updatedAt              DateTime? @default(now()) @db.Timestamp(6)
  // Role values: CONSUMER | TRADE | NDIS_COORDINATOR | ADMIN
  // (legacy "USER" is treated as CONSUMER by the app)
  role                   String?   @default("CONSUMER")
  cart                   Cart?
  reviews                Reviews[]
  order                  Order[]
  accountApplication     AccountApplication?
  quotes                 Quote[]
  standingOrders         StandingOrder[]
  subscriptions          Subscription[]
  deliverySites          DeliverySite[]
  negotiatedPrices       NegotiatedPrice[]
}

// Trade / NDIS coordinator account application.
// A consumer applies for an upgraded account; an admin approves it,
// which flips the user's role and grants access to the matching portal.
model AccountApplication {
  id              String   @id @default(dbgenerated("gen_random_uuid()"))
  userId          String   @unique
  // Which portal they are applying for: TRADE | NDIS_COORDINATOR
  requestedRole   String
  // PENDING | APPROVED | REJECTED
  status          String   @default("PENDING")
  // Business / organisation details
  businessName    String?
  abn             String?
  businessType    String?
  contactName     String?
  contactPhone    String?
  // NDIS-specific
  organisation    String?
  // 30-day account invoicing flag (admin sets on approval)
  creditApproved  Boolean  @default(false)
  notes           String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// Global, admin-editable settings. Stored as key/value so the team can change
// pricing rules without a code change. Values are JSON to allow numbers/bools/strings.
// Known keys (with defaults applied in the pricing service):
//   gstEnabled (bool)                 - whether GST is added at all
//   gstRate (number, e.g. 0.10)       - GST rate when enabled
//   ndisAnnualDiscountPct (number)    - % off for a 12-month NDIS supply
//   consumerSubscriptionDiscountPct   - % off recurring consumer orders
//   deliveryMode ("FLAT"|"POSTCODE")  - how delivery is charged
//   deliveryFlatFee (number)          - flat delivery fee
//   freeDeliveryThreshold (number)    - order total above which delivery is free (0 = off)
model Setting {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

// Volume pricing tiers for B2B trade accounts. A tier applies to a product
// when the ordered carton quantity is >= minQuantity. The highest matching
// tier wins. If productId is null the tier is a global default.
model PricingTier {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  productId    String?
  // null = TRADE default; could be extended to other roles later
  role         String   @default("TRADE")
  minQuantity  Int
  pricePerUnit Float
  label        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId, role, minQuantity])
}

// Per-product per-role price overrides (e.g. a specific NDIS price for a product).
// Optional — when absent the pricing service falls back to the product's retail price.
model PriceOverride {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  productId String
  role      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, role])
}

// Multi-site trade account — one account, multiple delivery sites (Phase 3).
model DeliverySite {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  label     String
  address   String
  phone     String?
  contact   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Negotiated (custom) pricing for a specific account, overriding volume tiers
// for large accounts (Phase 3). Highest priority in the pricing resolver.
model NegotiatedPrice {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  productId String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// Consumer subscription — recurring auto-delivery so customers never run out.
// The scheduler generates a real Order each cycle and applies the configurable
// consumer subscription discount.
model Subscription {
  id              String   @id @default(dbgenerated("gen_random_uuid()"))
  userId          String
  // ACTIVE | PAUSED | CANCELLED
  status          String   @default("ACTIVE")
  intervalDays    Int      @default(30)
  nextRunAt       DateTime
  shippingAddress String
  phone           String
  // Line items: [{ productId, quantity }]
  items           Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, nextRunAt])
}

// Standing / recurring trade order — scheduled auto-delivery for trade accounts
// (e.g. aged care facilities). The scheduler generates a real Order each cycle.
model StandingOrder {
  id              String   @id @default(dbgenerated("gen_random_uuid()"))
  userId          String
  // ACTIVE | PAUSED | CANCELLED
  status          String   @default("ACTIVE")
  // Cadence in days (e.g. 30 = monthly)
  intervalDays    Int      @default(30)
  nextRunAt       DateTime
  shippingAddress String
  phone           String
  // Line items: [{ productId, quantity }]
  items           Json
  paymentMethod   String   @default("Invoice")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, nextRunAt])
}

// NDIS quote created by a support coordinator on behalf of a participant.
model Quote {
  id              String      @id @default(dbgenerated("gen_random_uuid()"))
  quoteNumber     String      @unique
  // Coordinator who created the quote
  userId          String
  // DRAFT | SENT | CONVERTED
  status          String      @default("DRAFT")
  participantRef  String?
  planManagerEmail String?
  // One-off | Monthly | Annual
  supplyPeriod    String      @default("Monthly")
  // Totals (computed via the pricing service's buildTotals)
  subtotal        Float       @default(0)
  discount        Float       @default(0)
  delivery        Float       @default(0)
  gst             Float       @default(0)
  total           Float       @default(0)
  validUntil      DateTime?
  notes           String?
  // Set when the quote is converted into a real order
  convertedOrderId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           QuoteItem[]

  @@index([userId])
  @@index([status])
}

// General enquiry inbox. Covers the NDIS "funding support" path (a coordinator
// asks for payment-plan / hardship options when funding doesn't cover a quote)
// and B2B trade enquiries. Surfaced in the admin dashboard.
model Enquiry {
  id            String   @id @default(dbgenerated("gen_random_uuid()"))
  // FUNDING_SUPPORT | TRADE | GENERAL
  type          String   @default("GENERAL")
  // NEW | IN_PROGRESS | RESOLVED
  status        String   @default("NEW")
  // Who raised it (logged-in user if available)
  userId        String?
  name          String?
  email         String?
  phone         String?
  // Funding-support specifics
  participantNeed String?
  availableFunding String?
  message       String?
  // Optional link to the quote that triggered the enquiry
  quoteId       String?
  handledBy     String?
  handledAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([status])
}

model QuoteItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  quoteId      String
  productId    String
  productName  String
  size         String?
  absorbency   String?
  // Daily pads usage entered by the coordinator
  dailyPads    Int      @default(0)
  // Days in the chosen supply period (One-off=pack qty, Monthly=30, Annual=365)
  days         Int      @default(0)
  // total pads = dailyPads * days
  totalPads    Int      @default(0)
  unitPrice    Float    @default(0)
  lineTotal    Float    @default(0)
  createdAt    DateTime @default(now())
  quote        Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Product {
  id            String       @id @default(dbgenerated("gen_random_uuid()"))
  title         String
  images        String[]
  description   String?
  price         Float
  discount      Float
  stock         Int          @default(0)
  colors        String[]
  categoryId    String?
  more_details  String[]
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  isFeatured    Boolean      @default(false)
  deletedAt     DateTime?
  sizes         String[]
  subcategoryId String?
  cartItems     CartItem[]
  category      Category?    @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
  reviews       Reviews[]
  orderItems    OrderItem[]
}

model Reviews {
  id        String   @id @default(uuid())
  comment   String?
  createdAt DateTime @default(now())
  productId String
  rating    Int
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Category {
  id            String        @id @default(dbgenerated("gen_random_uuid()"))
  title         String        @unique
  slug          String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  id         String    @id @default(uuid())
  title      String
  slug       String
  categoryId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   Product[]
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@unique([categoryId, title])
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()"))
  token     String?    @unique
  userId    String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  cartId    String
  productId String
  quantity  Int      @default(1)
  // Set when the shopper opted into "Subscribe & Save" for this item
  // (2/4/6/12-month auto-refill). null = one-time purchase.
  subscriptionIntervalDays Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id                    String      @id @default(dbgenerated("gen_random_uuid()"))
  orderNumber           String      @unique
  userId                String?
  guestEmail            String?
  guestPhone            String?
  guestAddress          String?
  shippingAddress       String      @map("shipping_address")
  phone                 String
  email                 String
  subtotal              Float
  // Amount knocked off subtotal by a "Subscribe & Save" interval discount.
  discount              Float       @default(0)
  shippingCost          Float       @default(0)
  tax                   Float       @default(0)
  total                 Float
  paymentMethod         String      @default("Stripe")
  paymentStatus         String      @default("Pending")
  orderStatus           String      @default("Pending")
  // NDIS / Home Care Package funding info when the order is paid from a
  // participant's funding rather than by card. Shape depends on paymentMethod:
  //   NDIS: { participantName, ndisNumber, dob, fundingType, approved }
  //   HCP:  { participantName, hcpNumber, providerEmail, approved }
  fundingDetails        Json?
  statusHistory         Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?
  firstName                  String?
  lastName              String?
  items                 OrderItem[]
  user                  User?       @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  orderId      String
  productId    String
  productName  String
  productImage String?
  price        Float
  quantity     Int
  total        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String?
  location  String?
  quote     String
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id            String    @id @default(uuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String
  featuredImage String?
  authorId      String?
  category      String?
  tags          String[]
  views         Int       @default(0)
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
  @@index([authorId])
}



// Internal admin-team task / note board ("Team Tasks" admin page).
// Any admin can write a task/requirement/note; any admin can accept a task
// and move it through OPEN → IN_PROGRESS → DONE.
model TeamTask {
  id             String    @id @default(dbgenerated("gen_random_uuid()"))
  // TASK | REQUIREMENT | NOTE
  type           String    @default("TASK")
  title          String
  description    String?
  // OPEN | IN_PROGRESS | DONE
  status         String    @default("OPEN")
  // LOW | NORMAL | HIGH
  priority       String    @default("NORMAL")
  createdById    String
  createdByName  String
  acceptedById   String?
  acceptedByName String?
  acceptedAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Pre-launch waitlist signup (marketing popup). Master record per the launch
// plan: identity + postcode (sales evidence), country (export interest),
// buyer type (segmenting + B2B routing), consent timestamp (Spam Act 2003),
// and UTM source for ad attribution.
model WaitlistEntry {
  id        String    @id @default(dbgenerated("gen_random_uuid()"))
  name      String
  email     String    @unique
  postcode  String
  country   String    @default("Australia")
  // USER | CARER | PHARMACY | AGED_CARE | NDIS_PROVIDER | DISTRIBUTOR
  buyerType String
  consent   Boolean   @default(false)
  consentAt DateTime?
  utm       String?
  createdAt DateTime  @default(now())

  @@index([buyerType])
  @@index([createdAt])
}
