generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(dbgenerated("gen_random_uuid()"))
  name                   String
  email                  String    @unique
  password               String
  verify_email           Boolean?  @default(false)
  status                 String?   @default("ACTIVE")
  avatar                 String?
  mobile                 String?
  last_login_date        DateTime? @db.Timestamp(6)
  refresh_token          String?
  forgot_password_otp    String?
  forgot_password_expire DateTime? @db.Timestamp(6)
  cart                   Cart?
  order                  Order[]
  createdAt              DateTime? @default(now()) @db.Timestamp(6)
  updatedAt              DateTime? @default(now()) @db.Timestamp(6)
}



model Product {
  id                   String    @id @default(dbgenerated("gen_random_uuid()"))
  title                String
  images               String[]
  description          String?
  price                Float
  discount             Float
  stock                Int      @default(0)
  colors               String[]
  sized                String[]
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  more_details         String[]
  cartItems            CartItem[]
  reviews              Reviews[]
  orderItems  OrderItem[]
  isFeatured  Boolean    @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Reviews {
  id                  String   @id @default(dbgenerated("gen_random_uuid()"))
  product             Product[]
}

model Category {
  id                  String   @id @default(dbgenerated("gen_random_uuid()"))
  title               String   @unique
  slug                String   @unique
  product             Product[]
}

model Cart {
  id                  String    @id @default(dbgenerated("gen_random_uuid()"))
  token               String?    @unique
  userId              String?    @unique
  user                User?     @relation(fields: [userId], references:[id], onDelete:Cascade)
  items               CartItem[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}


model CartItem {
  id                  String   @id @default(dbgenerated("gen_random_uuid()"))
  cartId              String
  cart                Cart     @relation(fields:[cartId], references:[id], onDelete:Cascade)
  productId           String
  product             Product   @relation(fields:[productId], references:[id])
  quantity            Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt


  @@unique([cartId, productId])
}




// After CartItem model

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()" ))
  orderNumber     String      @unique           // human-readable, e.g., "ORD-20250518-001"
  userId          String?                       // null for guest orders
  user            User?       @relation(fields: [userId], references: [id])
  guestEmail      String?                       // for guest checkout
  guestPhone      String?
  guestAddress    String?
  shippingAddress String      @map("shipping_address") // full address (for both guest & user)
  phone           String                         // contact phone
  email           String                     // contact email
  items           OrderItem[]
  subtotal        Float
  shippingCost    Float       @default(0)
  tax             Float       @default(0)
  total           Float
  paymentMethod   String      @default("COD")    // "COD", "Stripe", "PayPal"
  paymentStatus   String      @default("Pending") // "Pending", "Paid", "Failed"
  orderStatus     String      @default("Pending") // "Pending", "Processing", "Shipped", "Delivered", "Cancelled"
  statusHistory   Json?                          // optional: track status changes
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()" ))
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  productName   String    // snapshot: product name at order time
  productImage  String?   // snapshot: primary image URL
  price         Float     // snapshot: price at order time
  quantity      Int
  total         Float     // price * quantity
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("order_items")
}