generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(dbgenerated("gen_random_uuid()"))
  name                   String
  email                  String    @unique
  password               String
  verify_email           Boolean?  @default(false)
  status                 String?   @default("ACTIVE")
  avatar                 String?
  mobile                 String?
  last_login_date        DateTime? @db.Timestamp(6)
  refresh_token          String?
  forgot_password_otp    String?
  forgot_password_expire DateTime? @db.Timestamp(6)
  createdAt              DateTime? @default(now()) @db.Timestamp(6)
  updatedAt              DateTime? @default(now()) @db.Timestamp(6)
  cart                   Cart?
  order                  Order[]
}

model Product {
  id           String      @id @default(dbgenerated("gen_random_uuid()"))
  title        String
  images       String[]
  description  String?
  price        Float
  discount     Float
  stock        Int         @default(0)
  colors       String[]
  sized        String[]
  categoryId   String?
  more_details String[]
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  isFeatured   Boolean     @default(false)
  deletedAt    DateTime?
  cartItems    CartItem[]
  category     Category?   @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
  reviews      Reviews[]   @relation("ProductToReviews")
}

model Reviews {
  id      String    @id @default(dbgenerated("gen_random_uuid()"))
  product Product[] @relation("ProductToReviews")
}

model Category {
  id      String    @id @default(dbgenerated("gen_random_uuid()"))
  title   String    @unique
  slug    String    @unique
  product Product[]
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()"))
  token     String?    @unique
  userId    String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id                    String      @id @default(dbgenerated("gen_random_uuid()"))
  orderNumber           String      @unique
  userId                String?
  guestEmail            String?
  guestPhone            String?
  guestAddress          String?
  shippingAddress       String      @map("shipping_address")
  phone                 String
  email                 String
  subtotal              Float
  shippingCost          Float       @default(0)
  tax                   Float       @default(0)
  total                 Float
  paymentMethod         String      @default("Stripe")
  paymentStatus         String      @default("Pending")
  orderStatus           String      @default("Pending")
  statusHistory         Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?
  name                  String?
  items                 OrderItem[]
  user                  User?       @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  orderId      String
  productId    String
  productName  String
  productImage String?
  price        Float
  quantity     Int
  total        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}
