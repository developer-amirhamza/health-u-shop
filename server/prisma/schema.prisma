generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String              @id @default(dbgenerated("gen_random_uuid()"))
  name                   String
  email                  String              @unique
  password               String
  verify_email           Boolean?            @default(false)
  status                 String?             @default("ACTIVE")
  avatar                 String?
  mobile                 String?
  last_login_date        DateTime?           @db.Timestamp(6)
  refresh_token          String?
  forgot_password_otp    String?
  forgot_password_expire DateTime?           @db.Timestamp(6)
  createdAt              DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt              DateTime?           @default(now()) @db.Timestamp(6)
  role                   String?             @default("CONSUMER")
  accountApplication     AccountApplication?
  cart                   Cart?
  deliverySites          DeliverySite[]
  negotiatedPrices       NegotiatedPrice[]
  quotes                 Quote[]
  reviews                Reviews[]
  standingOrders         StandingOrder[]
  subscriptions          Subscription[]
  order                  Order[]
}

model AccountApplication {
  id             String    @id @default(dbgenerated("gen_random_uuid()"))
  userId         String    @unique
  requestedRole  String
  status         String    @default("PENDING")
  businessName   String?
  abn            String?
  businessType   String?
  contactName    String?
  contactPhone   String?
  organisation   String?
  creditApproved Boolean   @default(false)
  notes          String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Setting {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model PricingTier {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  productId    String?
  role         String   @default("TRADE")
  minQuantity  Int
  pricePerUnit Float
  label        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId, role, minQuantity])
}

model PriceOverride {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  productId String
  role      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, role])
}

model DeliverySite {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  label     String
  address   String
  phone     String?
  contact   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NegotiatedPrice {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  productId String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Subscription {
  id              String   @id @default(dbgenerated("gen_random_uuid()"))
  userId          String
  status          String   @default("ACTIVE")
  intervalDays    Int      @default(30)
  nextRunAt       DateTime
  shippingAddress String
  phone           String
  items           Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, nextRunAt])
}

model StandingOrder {
  id              String   @id @default(dbgenerated("gen_random_uuid()"))
  userId          String
  status          String   @default("ACTIVE")
  intervalDays    Int      @default(30)
  nextRunAt       DateTime
  shippingAddress String
  phone           String
  items           Json
  paymentMethod   String   @default("Invoice")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, nextRunAt])
}

model Quote {
  id               String      @id @default(dbgenerated("gen_random_uuid()"))
  quoteNumber      String      @unique
  userId           String
  status           String      @default("DRAFT")
  participantRef   String?
  planManagerEmail String?
  supplyPeriod     String      @default("Monthly")
  subtotal         Float       @default(0)
  discount         Float       @default(0)
  delivery         Float       @default(0)
  gst              Float       @default(0)
  total            Float       @default(0)
  validUntil       DateTime?
  notes            String?
  convertedOrderId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            QuoteItem[]

  @@index([userId])
  @@index([status])
}

model Enquiry {
  id               String    @id @default(dbgenerated("gen_random_uuid()"))
  type             String    @default("GENERAL")
  status           String    @default("NEW")
  userId           String?
  name             String?
  email            String?
  phone            String?
  participantNeed  String?
  availableFunding String?
  message          String?
  quoteId          String?
  handledBy        String?
  handledAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([type])
  @@index([status])
}

model QuoteItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  quoteId     String
  productId   String
  productName String
  size        String?
  absorbency  String?
  dailyPads   Int      @default(0)
  days        Int      @default(0)
  totalPads   Int      @default(0)
  unitPrice   Float    @default(0)
  lineTotal   Float    @default(0)
  createdAt   DateTime @default(now())
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Product {
  id            String       @id @default(dbgenerated("gen_random_uuid()"))
  title         String
  images        String[]
  description   String?
  price         Float
  discount      Float
  stock         Int          @default(0)
  colors        String[]
  categoryId    String?
  more_details  String[]
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  isFeatured    Boolean      @default(false)
  deletedAt     DateTime?
  sizes         String[]
  subcategoryId String?
  cartItems     CartItem[]
  category      Category?    @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
  reviews       Reviews[]
  orderItems    OrderItem[]
}

model Reviews {
  id        String   @id @default(uuid())
  comment   String?
  createdAt DateTime @default(now())
  productId String
  rating    Int
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Category {
  id            String        @id @default(dbgenerated("gen_random_uuid()"))
  title         String        @unique
  slug          String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  id         String    @id @default(uuid())
  title      String
  slug       String
  categoryId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   Product[]
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@unique([categoryId, title])
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()"))
  token     String?    @unique
  userId    String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id                       String   @id @default(dbgenerated("gen_random_uuid()"))
  cartId                   String
  productId                String
  quantity                 Int      @default(1)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  subscriptionIntervalDays Int?
  cart                     Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product                  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id                    String      @id @default(dbgenerated("gen_random_uuid()"))
  orderNumber           String      @unique
  userId                String?
  guestEmail            String?
  guestPhone            String?
  guestAddress          String?
  shippingAddress       String      @map("shipping_address")
  phone                 String
  email                 String
  subtotal              Float
  shippingCost          Float       @default(0)
  tax                   Float       @default(0)
  total                 Float
  paymentMethod         String      @default("Stripe")
  paymentStatus         String      @default("Pending")
  orderStatus           String      @default("Pending")
  statusHistory         Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?
  name                  String?
  discount              Float       @default(0)
  items                 OrderItem[]
  user                  User?       @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  orderId      String
  productId    String
  productName  String
  productImage String?
  price        Float
  quantity     Int
  total        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String?
  location  String?
  quote     String
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id            String    @id @default(uuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String
  featuredImage String?
  authorId      String?
  category      String?
  tags          String[]
  views         Int       @default(0)
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
  @@index([authorId])
}
